</style>

<script is:inline>
	document.addEventListener("DOMContentLoaded", function () {

		function formatSize(bytes) {
			if (bytes < 1024) return bytes + " B";
			if (bytes < 1048576) return (bytes / 1024).toFixed(1) + " KB";
			return (bytes / 1048576).toFixed(1) + " MB";
		}

		// =====================================================================
		// Signature Canvas
		// =====================================================================
		document.querySelectorAll(".emdash-form-embed__signature-pad").forEach(function (pad) {
			var canvas = pad.querySelector(".emdash-form-embed__signature-canvas");
			var hiddenInput = pad.querySelector("input[type=hidden]");
			var clearBtn = pad.querySelector(".emdash-form-embed__signature-clear");
			if (!canvas || !hiddenInput) return;

			var ctx = canvas.getContext("2d");
			var drawing = false;
			var hasDrawn = false;

			function getPos(e) {
				var rect = canvas.getBoundingClientRect();
				var scaleX = canvas.width / rect.width;
				var scaleY = canvas.height / rect.height;
				if (e.touches && e.touches[0]) {
					return { x: (e.touches[0].clientX - rect.left) * scaleX, y: (e.touches[0].clientY - rect.top) * scaleY };
				}
				return { x: (e.clientX - rect.left) * scaleX, y: (e.clientY - rect.top) * scaleY };
			}

			function startDraw(e) {
				e.preventDefault();
				drawing = true;
				hasDrawn = true;
				var pos = getPos(e);
				ctx.beginPath();
				ctx.moveTo(pos.x, pos.y);
			}

			function draw(e) {
				if (!drawing) return;
				e.preventDefault();
				var pos = getPos(e);
				ctx.lineWidth = 2;
				ctx.lineCap = "round";
				ctx.lineJoin = "round";
				ctx.strokeStyle = "#1f2937";
				ctx.lineTo(pos.x, pos.y);
				ctx.stroke();
			}

			function stopDraw() {
				if (!drawing) return;
				drawing = false;
				if (hasDrawn) {
					hiddenInput.value = canvas.toDataURL("image/png");
				}
			}

			canvas.addEventListener("mousedown", startDraw);
			canvas.addEventListener("mousemove", draw);
			canvas.addEventListener("mouseup", stopDraw);
			canvas.addEventListener("mouseleave", stopDraw);
			canvas.addEventListener("touchstart", startDraw, { passive: false });
			canvas.addEventListener("touchmove", draw, { passive: false });
			canvas.addEventListener("touchend", stopDraw);

			if (clearBtn) {
				clearBtn.addEventListener("click", function () {
					ctx.clearRect(0, 0, canvas.width, canvas.height);
					hiddenInput.value = "";
					hasDrawn = false;
				});
			}

			// Make canvas responsive
			function resizeCanvas() {
				var rect = canvas.parentElement.getBoundingClientRect();
				canvas.style.width = "100%";
				canvas.style.height = "auto";
			}
			resizeCanvas();
		});

		// =====================================================================
		// Rating Stars
		// =====================================================================
		document.querySelectorAll(".emdash-form-embed__rating-group").forEach(function (group) {
			var stars = group.querySelectorAll(".emdash-form-embed__rating-star");
			var currentValue = 0;

			function updateStars(value, animate) {
				stars.forEach(function (star) {
					var v = parseInt(star.dataset.value);
					var span = star.querySelector(".emdash-form-embed__star");
					if (v <= value) {
						span.classList.add("efb-star-active");
						if (animate) {
							span.classList.remove("efb-star-animate");
							void span.offsetWidth;
							span.classList.add("efb-star-animate");
						}
					} else {
						span.classList.remove("efb-star-active");
					}
				});
			}

			stars.forEach(function (star) {
				star.addEventListener("mouseenter", function () {
					updateStars(parseInt(star.dataset.value), false);
				});

				star.addEventListener("click", function () {
					currentValue = parseInt(star.dataset.value);
					var radio = star.querySelector("input[type=radio]");
					if (radio) radio.checked = true;
					updateStars(currentValue, true);
				});
			});

			group.addEventListener("mouseleave", function () {
				updateStars(currentValue, false);
			});
		});

		// =====================================================================
		// Searchable Select
		// =====================================================================
		document.querySelectorAll(".efb-select-wrap").forEach(function (wrap) {
			var trigger = wrap.querySelector(".efb-select-trigger");
			var dropdown = wrap.querySelector(".efb-select-dropdown");
			var search = wrap.querySelector(".efb-select-search");
			var options = wrap.querySelectorAll(".efb-select-option");
			var label = wrap.querySelector(".efb-select-label");
			var hidden = wrap.querySelector("input[type=hidden]");
			var placeholder = wrap.dataset.placeholder || "Select...";

			function open() {
				dropdown.hidden = false;
				wrap.classList.add("efb-open");
				search.value = "";
				filterOptions("");
				search.focus();
			}

			function close() {
				dropdown.hidden = true;
				wrap.classList.remove("efb-open");
			}

			function filterOptions(query) {
				var q = query.toLowerCase();
				options.forEach(function (opt) {
					var text = opt.textContent.toLowerCase();
					opt.classList.toggle("efb-hidden", q.length > 0 && !text.includes(q));
				});
			}

			trigger.addEventListener("click", function (e) {
				e.stopPropagation();
				if (dropdown.hidden) open(); else close();
			});

			search.addEventListener("input", function () {
				filterOptions(search.value);
			});

			search.addEventListener("keydown", function (e) {
				if (e.key === "Escape") close();
			});

			options.forEach(function (opt) {
				opt.addEventListener("click", function () {
					var val = opt.dataset.value;
					hidden.value = val;
					label.textContent = opt.textContent || placeholder;
					options.forEach(function (o) { o.classList.remove("efb-selected"); });
					opt.classList.add("efb-selected");
					close();
				});
			});

			document.addEventListener("click", function (e) {
				if (!wrap.contains(e.target)) close();
			});
		});

		// =====================================================================
		// Searchable Multiselect
		// =====================================================================
		document.querySelectorAll(".efb-multiselect-wrap").forEach(function (wrap) {
			var trigger = wrap.querySelector(".efb-multiselect-trigger");
			var dropdown = wrap.querySelector(".efb-select-dropdown");
			var search = wrap.querySelector(".efb-select-search");
			var options = wrap.querySelectorAll(".efb-select-option");
			var chipsContainer = wrap.querySelector(".efb-multiselect-chips");
			var placeholderEl = wrap.querySelector(".efb-multiselect-placeholder");
			var fieldName = wrap.dataset.fieldName;
			var maxSelections = parseInt(wrap.dataset.maxSelections) || 0;
			var selected = [];

			function open() {
				dropdown.hidden = false;
				wrap.classList.add("efb-open");
				search.value = "";
				filterOptions("");
				search.focus();
			}

			function close() {
				dropdown.hidden = true;
				wrap.classList.remove("efb-open");
			}

			function filterOptions(query) {
				var q = query.toLowerCase();
				options.forEach(function (opt) {
					var text = opt.textContent.toLowerCase();
					opt.classList.toggle("efb-hidden", q.length > 0 && !text.includes(q));
				});
			}

			function renderChips() {
				chipsContainer.innerHTML = "";
				// Remove old hidden inputs for this field
				wrap.querySelectorAll("input[type=hidden]").forEach(function (inp) { inp.remove(); });

				selected.forEach(function (val) {
					var optEl = wrap.querySelector('.efb-select-option[data-value="' + CSS.escape(val) + '"]');
					var labelText = optEl ? optEl.textContent.replace("✓", "").trim() : val;

					var chip = document.createElement("span");
					chip.className = "efb-ms-chip";
					var chipLabel = document.createElement("span");
					chipLabel.textContent = labelText;
					chip.appendChild(chipLabel);
					var removeBtn = document.createElement("button");
					removeBtn.type = "button";
					removeBtn.className = "efb-ms-chip-remove";
					removeBtn.innerHTML = '<svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="2" y1="2" x2="8" y2="8"/><line x1="8" y1="2" x2="2" y2="8"/></svg>';
					removeBtn.addEventListener("click", function (e) {
						e.stopPropagation();
						toggleValue(val);
					});
					chip.appendChild(removeBtn);
					chipsContainer.appendChild(chip);

					var hiddenInput = document.createElement("input");
					hiddenInput.type = "hidden";
					hiddenInput.name = fieldName;
					hiddenInput.value = val;
					wrap.appendChild(hiddenInput);
				});

				placeholderEl.style.display = selected.length > 0 ? "none" : "";

				options.forEach(function (opt) {
					opt.classList.toggle("efb-selected", selected.includes(opt.dataset.value));
				});
			}

			function toggleValue(val) {
				var idx = selected.indexOf(val);
				if (idx === -1) {
					if (maxSelections > 0 && selected.length >= maxSelections) return;
					selected.push(val);
				} else {
					selected.splice(idx, 1);
				}
				renderChips();
			}

			trigger.addEventListener("click", function (e) {
				e.stopPropagation();
				if (dropdown.hidden) open(); else close();
			});

			search.addEventListener("input", function () {
				filterOptions(search.value);
			});

			search.addEventListener("keydown", function (e) {
				if (e.key === "Escape") close();
			});

			options.forEach(function (opt) {
				opt.addEventListener("click", function (e) {
					e.stopPropagation();
					toggleValue(opt.dataset.value);
				});
			});

			document.addEventListener("click", function (e) {
				if (!wrap.contains(e.target)) close();
			});

			renderChips();
		});

		// =====================================================================
		// File Upload (Drag & Drop)
		// =====================================================================
		document.querySelectorAll(".efb-file-wrap").forEach(function (wrap) {
			var dropzone = wrap.querySelector(".efb-file-dropzone");
			var fileInput = wrap.querySelector(".efb-file-input");
			var fileList = wrap.querySelector(".efb-file-list");
			var maxSize = parseFloat(wrap.dataset.maxSize) || 10;
			var maxFiles = parseInt(wrap.dataset.maxFiles) || 1;
			var isMultiple = wrap.dataset.multiple === "true";
			var selectedFiles = [];

			function renderFileList() {
				fileList.innerHTML = "";
				selectedFiles.forEach(function (file, i) {
					var item = document.createElement("div");
					item.className = "efb-file-item";

					var info = document.createElement("div");
					info.className = "efb-file-item-info";
					var nameSpan = document.createElement("span");
					nameSpan.className = "efb-file-item-name";
					nameSpan.textContent = file.name;
					var sizeSpan = document.createElement("span");
					sizeSpan.className = "efb-file-item-size";
					sizeSpan.textContent = formatSize(file.size);
					info.appendChild(nameSpan);
					info.appendChild(sizeSpan);

					var removeBtn = document.createElement("button");
					removeBtn.type = "button";
					removeBtn.className = "efb-file-item-remove";
					removeBtn.textContent = "×";
					removeBtn.addEventListener("click", function () {
						selectedFiles.splice(i, 1);
						syncToInput();
						renderFileList();
					});

					item.appendChild(info);
					item.appendChild(removeBtn);
					fileList.appendChild(item);
				});
			}

			function syncToInput() {
				var dt = new DataTransfer();
				selectedFiles.forEach(function (f) { dt.items.add(f); });
				fileInput.files = dt.files;
			}

			function addFiles(files) {
				for (var i = 0; i < files.length; i++) {
					var file = files[i];
					if (file.size > maxSize * 1024 * 1024) {
						alert(file.name + " exceeds the maximum file size of " + maxSize + "MB.");
						continue;
					}
					if (!isMultiple) {
						selectedFiles = [file];
						break;
					}
					if (selectedFiles.length >= maxFiles) {
						alert("Maximum " + maxFiles + " file(s) allowed.");
						break;
					}
					selectedFiles.push(file);
				}
				syncToInput();
				renderFileList();
			}

			dropzone.addEventListener("click", function () {
				fileInput.click();
			});

			fileInput.addEventListener("change", function () {
				if (fileInput.files.length > 0) {
					addFiles(fileInput.files);
				}
			});

			dropzone.addEventListener("dragover", function (e) {
				e.preventDefault();
				dropzone.classList.add("efb-dragover");
			});

			dropzone.addEventListener("dragleave", function () {
				dropzone.classList.remove("efb-dragover");
			});

			dropzone.addEventListener("drop", function (e) {
				e.preventDefault();
				dropzone.classList.remove("efb-dragover");
				if (e.dataTransfer && e.dataTransfer.files.length > 0) {
					addFiles(e.dataTransfer.files);
				}
			});
		});

		// =====================================================================
		// Form Submission
		// =====================================================================
		document.querySelectorAll("form.emdash-form-embed").forEach(function (form) {
			form.addEventListener("submit", async function (e) {
				e.preventDefault();

				var fieldMap = JSON.parse(form.dataset.fieldMap || "{}");
				var formData = new FormData(form);
				var formId = formData.get("formId");

				// Collect answers: map field names to fieldIds
				var answers = [];
				var seen = new Set();

				for (var pair of formData.entries()) {
					var name = pair[0];
					if (name === "formId" || seen.has(name)) continue;
					var fieldId = fieldMap[name];
					if (!fieldId) continue;
					seen.add(name);

					// Collect all values for this field (handles multi-select/checkbox)
					var allValues = formData.getAll(name);
					var value = allValues.length === 1 ? allValues[0] : allValues;
					answers.push({ fieldId: fieldId, value: value });
				}

				var submitBtn = form.querySelector(".emdash-form-embed__submit");
				if (submitBtn) {
					submitBtn.disabled = true;
					submitBtn.textContent = "Submitting...";
				}

				// Remove previous messages
				var prevMsg = form.querySelector(".emdash-form-embed__message");
				if (prevMsg) prevMsg.remove();

				try {
					var res = await fetch(form.action, {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ formId: formId, answers: answers }),
					});

					var result = await res.json();

					if (res.ok && result.data) {
						var msg = document.createElement("div");
						msg.className =
							"emdash-form-embed__message emdash-form-embed__message--success";
						var thankYou = result.data.thankYou;
						if (thankYou && thankYou.mode === "redirect" && thankYou.redirectUrl) {
							window.location.href = thankYou.redirectUrl;
							return;
						}
						var text =
							(thankYou && thankYou.message) ||
							"Thank you! Your submission has been received.";
						var tracking = result.data.trackingCode;
						msg.textContent =
							tracking && thankYou && thankYou.includeTrackingCode
								? text + " (Ref: " + tracking + ")"
								: text;

						// In dev/test mode, show the magic portal link
						if (result.data._devPortalUrl) {
							var devLink = document.createElement("div");
							devLink.className = "emdash-form-embed__message";
							devLink.style.cssText = "margin-top:8px;padding:8px 12px;background:#fef3c7;border:1px solid #f59e0b;border-radius:8px;font-size:12px;color:#92400e;word-break:break-all";
							devLink.innerHTML = "<strong>🔧 Dev Mode — Portal URL:</strong><br><a href=\"" +
								result.data._devPortalUrl.replace(/"/g, "&quot;") +
								"\" target=\"_blank\" style=\"color:#1d4ed8;text-decoration:underline\">" +
								result.data._devPortalUrl.replace(/</g, "&lt;") + "</a>";
							msg.appendChild(devLink);
						}

						form.replaceWith(msg);
					} else {
						var msg = document.createElement("div");
						msg.className =
							"emdash-form-embed__message emdash-form-embed__message--error";
						msg.textContent =
							(result.error && result.error.message) ||
							"Something went wrong. Please try again.";
						var actions = form.querySelector(".emdash-form-embed__actions");
						if (actions) actions.before(msg);
					}
				} catch (_err) {
					var msg = document.createElement("div");
					msg.className =
						"emdash-form-embed__message emdash-form-embed__message--error";
					msg.textContent =
						"Network error. Please check your connection and try again.";
					var actions = form.querySelector(".emdash-form-embed__actions");
					if (actions) actions.before(msg);
				} finally {
					if (submitBtn) {
						submitBtn.disabled = false;
						submitBtn.textContent =
							submitBtn.dataset.originalLabel || "Submit";
					}
				}
			});

			// Store original label for restore after error
			var btn = form.querySelector(".emdash-form-embed__submit");
			if (btn) btn.dataset.originalLabel = btn.textContent || "Submit";
		});
	});
</script>
