---
/**
 * FormEmbed — Portable Text block component for embedding forms.
 *
 * Fetches the saved form definition from the plugin API and renders
 * all fields server-side. Submissions POST to the forms.submit route.
 */

interface Props {
	node: { formId: string };
}

const { node } = Astro.props;
const formId = node.formId;

if (!formId) return;

// Fetch form definition from the forms-builder plugin API
const response = await fetch(
	new URL("/_emdash/api/plugins/emdash-form-builder/forms.get", Astro.url),
	{
		method: "POST",
		headers: { "Content-Type": "application/json" },
		body: JSON.stringify({ formId }),
	},
);

if (!response.ok) return;

const body = (await response.json()) as {
	data?: {
		form?: {
			definition?: {
				meta: { name: string; slug: string };
				fields: Record<
					string,
					{
						id: string;
						type: string;
						name: string;
						label: string;
						defaultValue: string;
						ui: {
							placeholder: string;
							width: string;
							helpText: string;
							style?: {
								marginTop?: string;
								marginBottom?: string;
								padding?: string;
								borderRadius?: string;
								backgroundColor?: string;
								labelFontSize?: string;
								labelFontWeight?: string;
								inputFontSize?: string;
								placeholderColor?: string;
								borderStyle?: string;
								focusBorderColor?: string;
								errorBorderColor?: string;
							};
						};
						validation: { required: boolean };
						options?: Array<{ label: string; value: string }>;
						ratingConfig?: {
							maxRating: number;
							iconType: string;
							allowHalf: boolean;
						};
						fileConfig?: {
							allowedTypes: string;
							maxSizeMb: number;
							maxFiles: number;
							multiple: boolean;
							showPreview: boolean;
							dragDropArea: boolean;
						};
						signatureConfig?: {
							mode: string;
							showClearButton: boolean;
						};
						multiselectConfig?: {
							maxSelections: number;
						};
					}
				>;
				steps: Array<{ id: string; title: string; fields: string[] }>;
				submitButton?: {
					label: string;
					size?: string;
					align?: string;
					variant?: string;
					backgroundColor?: string;
					textColor?: string;
					borderRadius?: string;
					borderColor?: string;
					fontSize?: string;
					fontWeight?: string;
					paddingX?: string;
					paddingY?: string;
					showReset?: boolean;
					resetLabel?: string;
					customClass?: string;
				};
			};
		};
	};
};

const definition = body.data?.form?.definition;
if (!definition) return;

const submitUrl = `/_emdash/api/plugins/emdash-form-builder/forms.submit`;
const btn = definition.submitButton;
const btnLabel = btn?.label || "Submit";
const btnAlign = btn?.align || "right";
const alignMap: Record<string, string> = {
	left: "flex-start",
	center: "center",
	right: "flex-end",
	full: "stretch",
};

// Build inline style for submit button from saved config
const btnStyle = [
	btn?.backgroundColor ? `background-color:${btn.backgroundColor}` : "",
	btn?.textColor ? `color:${btn.textColor}` : "",
	btn?.borderRadius ? `border-radius:${btn.borderRadius}` : "",
	btn?.borderColor ? `border-color:${btn.borderColor}` : "",
	btn?.fontSize ? `font-size:${btn.fontSize}` : "",
	btn?.fontWeight ? `font-weight:${btn.fontWeight}` : "",
	btn?.paddingX ? `padding-left:${btn.paddingX};padding-right:${btn.paddingX}` : "",
	btn?.paddingY ? `padding-top:${btn.paddingY};padding-bottom:${btn.paddingY}` : "",
	btn?.variant === "outline" ? "background-color:transparent;border:1px solid" : "",
	btn?.variant === "ghost" ? "background-color:transparent;border:none" : "",
]
	.filter(Boolean)
	.join(";");

// Collect fields in step order
const orderedFields = definition.steps.flatMap((step) =>
	step.fields
		.map((fieldId) => definition.fields[fieldId])
		.filter((f): f is NonNullable<typeof f> => f != null),
);

function inputType(fieldType: string): string {
	switch (fieldType) {
		case "email":
			return "email";
		case "tel":
		case "mobile":
		case "phone":
			return "tel";
		case "number":
		case "input_price":
		case "prcfld":
			return "number";
		case "password":
			return "password";
		case "date":
			return "date";
		case "file_upload":
		case "file":
			return "file";
		case "url":
			return "url";
		case "range":
			return "range";
		case "color_picker":
			return "color";
		case "hidden":
			return "hidden";
		default:
			return "text";
	}
}

const choiceTypes = new Set(["select", "multiselect", "radio", "checkbox", "yes_no"]);
const textareaTypes = new Set(["textarea"]);
// Types with special rendering (not a plain <input>)
const ratingTypes = new Set(["rating", "rating_star"]);
const fivePointTypes = new Set(["five_point", "five_point_scale"]);
const toggleTypes = new Set(["toggle"]);
const signatureTypes = new Set(["signature"]);
const dividerTypes = new Set(["divider"]);
const totalPriceTypes = new Set(["ttlprc", "total_price"]);
const hiddenTypes = new Set(["hidden"]);
const fileTypes = new Set(["file", "file_upload"]);

// Build a name -> fieldId mapping so the client script can construct the answers array
const fieldNameToId: Record<string, string> = {};
for (const field of orderedFields) {
	fieldNameToId[field.name] = field.id;
}

// JSON-LD schema — only on pages with a form (free version includes publisher links)
const pageUrl = Astro.url.href;
const schemaLd = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"@id": `${pageUrl}#webpage`,
	url: pageUrl,
	mentions: {
		"@type": "SoftwareApplication",
		"@id": "https://github.com/hassantafreshi/emdash-forms-builder#software",
		name: "EmForm Builder",
		alternateName: "Free Form Builder Plugin for EmDash CMS",
		description:
			"EmForm Builder is an EmDash CMS plugin for creating contact forms, payment forms, and survey forms.",
		applicationCategory: ["BusinessApplication", "WebApplication"],
		operatingSystem: "EmDash CMS",
		softwareVersion: "0.1.0",
		url: "https://github.com/hassantafreshi/emdash-forms-builder",
		isAccessibleForFree: true,
		keywords: [
			"form builder",
			"contact form plugin",
			"payment form plugin",
			"survey form plugin",
			"email notification form",
		],
		publisher: {
			"@type": "Organization",
			"@id": "https://whitestudio.team/#organization",
			name: "EmForm Builder - Free Form Builder Plugin for EmDash CMS",
			url: "https://whitestudio.team",
		},
	},
};
---

<form
	class="emdash-form-embed"
	action={submitUrl}
	method="post"
	aria-label={definition.meta.name}
	data-field-map={JSON.stringify(fieldNameToId)}
>
	<input type="hidden" name="formId" value={formId} />

	<div class="emdash-form-embed__fields">
		{orderedFields.map((field) => {
			const fs = field.ui.style;
			const wrapStyle = [
				fs?.marginTop ? `margin-top:${fs.marginTop}` : "",
				fs?.marginBottom ? `margin-bottom:${fs.marginBottom}` : "",
				fs?.padding ? `padding:${fs.padding}` : "",
			].filter(Boolean).join(";") || undefined;
			const lblStyle = [
				fs?.labelFontSize ? `font-size:${fs.labelFontSize}` : "",
				fs?.labelFontWeight ? `font-weight:${fs.labelFontWeight}` : "",
			].filter(Boolean).join(";") || undefined;
			const inpStyle = [
				fs?.borderRadius ? `border-radius:${fs.borderRadius}` : "",
				fs?.borderStyle ? `border-style:${fs.borderStyle}` : "",
				fs?.backgroundColor ? `background-color:${fs.backgroundColor}` : "",
				fs?.inputFontSize ? `font-size:${fs.inputFontSize}` : "",
			].filter(Boolean).join(";") || undefined;

			/* ---- Divider (no label, no input) ---- */
			if (dividerTypes.has(field.type)) {
				return <hr class="emdash-form-embed__divider" style={wrapStyle} />;
			}

			/* ---- Hidden field (invisible) ---- */
			if (hiddenTypes.has(field.type)) {
				return <input type="hidden" name={field.name} value={field.defaultValue} />;
			}

			return (
			<div
				class={`emdash-form-embed__group${field.ui.width === "half" ? " emdash-form-embed__group--half" : field.ui.width === "third" ? " emdash-form-embed__group--third" : ""}`}
				style={wrapStyle}
			>
				<label for={`efb-${field.name}`} class="emdash-form-embed__label" style={lblStyle}>
					{field.label}
					{field.validation.required && <span class="emdash-form-embed__required">*</span>}
				</label>

				{/* ---- Textarea ---- */}
				{textareaTypes.has(field.type) ? (
					<textarea
						id={`efb-${field.name}`}
						name={field.name}
						class="emdash-form-embed__input emdash-form-embed__textarea"
						placeholder={field.ui.placeholder}
						required={field.validation.required}
						rows="4"
						style={inpStyle}
					>
						{field.defaultValue}
					</textarea>

				/* ---- Select (searchable dropdown) ---- */
				) : choiceTypes.has(field.type) && field.type === "select" ? (
					<div class="efb-select-wrap" data-field-name={field.name} data-placeholder={field.ui.placeholder || "Select..."}>
						<input type="hidden" id={`efb-${field.name}`} name={field.name} required={field.validation.required ? true : undefined} />
						<button type="button" class="efb-select-trigger emdash-form-embed__input" aria-haspopup="listbox" style={inpStyle}>
							<span class="efb-select-label">{field.ui.placeholder || "Select..."}</span>
							<span class="efb-select-arrow">&#9662;</span>
						</button>
						<div class="efb-select-dropdown" role="listbox" hidden>
							<input type="text" class="efb-select-search" placeholder="Search..." autocomplete="off" />
							<div class="efb-select-options">
								{(field.options ?? []).map((opt) => (
									<div class="efb-select-option" data-value={opt.value} role="option">{opt.label}</div>
								))}
							</div>
						</div>
					</div>

				/* ---- Multiselect (searchable dropdown with chips) ---- */
				) : choiceTypes.has(field.type) && field.type === "multiselect" ? (
					<div class="efb-multiselect-wrap" data-field-name={field.name} data-max-selections={field.multiselectConfig?.maxSelections || 0}>
						<div class="efb-multiselect-trigger emdash-form-embed__input" tabindex="0" role="combobox" aria-haspopup="listbox" style={inpStyle}>
							<div class="efb-multiselect-chips"></div>
							<span class="efb-multiselect-placeholder">Select options...</span>
							<span class="efb-select-arrow">&#9662;</span>
						</div>
						<div class="efb-select-dropdown" role="listbox" hidden>
							<input type="text" class="efb-select-search" placeholder="Search..." autocomplete="off" />
							<div class="efb-select-options">
								{(field.options ?? []).map((opt) => (
									<div class="efb-select-option" data-value={opt.value} role="option">
										<span class="efb-ms-check">&#10003;</span>
										{opt.label}
									</div>
								))}
							</div>
						</div>
					</div>

				/* ---- Radio / Yes-No ---- */
				) : choiceTypes.has(field.type) && (field.type === "radio" || field.type === "yes_no") ? (
					<div class="emdash-form-embed__radio-group">
						{(field.type === "yes_no"
							? [
									{ label: "Yes", value: "yes" },
									{ label: "No", value: "no" },
								]
							: field.options ?? []
						).map((opt) => (
							<label class="emdash-form-embed__radio-label">
								<input
									type="radio"
									name={field.name}
									value={opt.value}
									required={field.validation.required}
								/>
								{opt.label}
							</label>
						))}
					</div>

				/* ---- Checkbox ---- */
				) : choiceTypes.has(field.type) && field.type === "checkbox" ? (
					<div class="emdash-form-embed__checkbox-group">
						{(field.options ?? []).map((opt) => (
							<label class="emdash-form-embed__checkbox-label">
								<input type="checkbox" name={field.name} value={opt.value} />
								{opt.label}
							</label>
						))}
					</div>

				/* ---- Toggle (switch) ---- */
				) : toggleTypes.has(field.type) ? (
					<label class="emdash-form-embed__toggle-label">
						<input
							type="checkbox"
							name={field.name}
							value="1"
							class="emdash-form-embed__toggle-input"
						/>
						<span class="emdash-form-embed__toggle-switch"></span>
					</label>

				/* ---- Rating (stars) ---- */
				) : ratingTypes.has(field.type) ? (
					<div class="emdash-form-embed__rating-group" data-field-name={field.name} data-max-rating={field.ratingConfig?.maxRating || 5}>
						{Array.from({ length: field.ratingConfig?.maxRating || 5 }, (_, i) => i + 1).map((star) => (
							<label class="emdash-form-embed__rating-star" data-value={star}>
								<input type="radio" name={field.name} value={String(star)} required={field.validation.required} />
								<span class="emdash-form-embed__star">&#9733;</span>
							</label>
						))}
					</div>

				/* ---- Five-point scale ---- */
				) : fivePointTypes.has(field.type) ? (
					<div class="emdash-form-embed__scale-group">
						{[1, 2, 3, 4, 5].map((n) => (
							<label class="emdash-form-embed__scale-option">
								<input type="radio" name={field.name} value={String(n)} required={field.validation.required} />
								<span>{n}</span>
							</label>
						))}
					</div>

				/* ---- Signature ---- */
				) : signatureTypes.has(field.type) ? (
					<div class="emdash-form-embed__signature-pad" data-field-name={field.name} data-show-clear={field.signatureConfig?.showClearButton !== false ? "true" : "false"}>
						<canvas class="emdash-form-embed__signature-canvas" width="400" height="150"></canvas>
						<input type="hidden" name={field.name} />
						{field.signatureConfig?.showClearButton !== false && (
							<button type="button" class="emdash-form-embed__signature-clear">Clear</button>
						)}
					</div>

				/* ---- Total price (read-only) ---- */
				) : totalPriceTypes.has(field.type) ? (
					<div class="emdash-form-embed__total-price" data-field-name={field.name}>
						<span class="emdash-form-embed__total-value">0.00</span>
						<input type="hidden" name={field.name} value="0" />
					</div>

				/* ---- Default: standard input (text, email, tel, number, password, date, url, range, color, prcfld) ---- */
				) : fileTypes.has(field.type) ? (
					<div class="efb-file-wrap" data-field-name={field.name} data-allowed-types={field.fileConfig?.allowedTypes || ""} data-max-size={field.fileConfig?.maxSizeMb || 10} data-max-files={field.fileConfig?.maxFiles || 1} data-multiple={field.fileConfig?.multiple ? "true" : "false"}>
						<div class="efb-file-dropzone">
							<div class="efb-file-dropzone-icon">&#8682;</div>
							<p class="efb-file-dropzone-text">Drag & drop files here or <span class="efb-file-browse">browse</span></p>
							{field.fileConfig?.allowedTypes && (
								<p class="efb-file-dropzone-hint">Allowed: {field.fileConfig.allowedTypes}</p>
							)}
							<p class="efb-file-dropzone-hint">Max size: {field.fileConfig?.maxSizeMb || 10}MB</p>
						</div>
						<input type="file" name={field.name} class="efb-file-input" accept={field.fileConfig?.allowedTypes || undefined} multiple={field.fileConfig?.multiple ? true : undefined} style="display:none" />
						<div class="efb-file-list"></div>
					</div>
				) : (
					<input
						id={`efb-${field.name}`}
						name={field.name}
						type={inputType(field.type)}
						class="emdash-form-embed__input"
						placeholder={field.ui.placeholder}
						value={field.defaultValue}
						required={field.validation.required}
						style={inpStyle}
					/>
				)}

				{field.ui.helpText && <p class="emdash-form-embed__help">{field.ui.helpText}</p>}
			</div>
		);})}
	</div>

	<div class="emdash-form-embed__actions" style={`justify-content:${alignMap[btnAlign] || "flex-end"}`}>
		{btn?.showReset && (
			<button type="reset" class="emdash-form-embed__reset">{btn.resetLabel || "Reset"}</button>
		)}
		<button
			type="submit"
			class={`emdash-form-embed__submit ${btn?.customClass || ""}`.trim()}
			style={btnStyle || undefined}
		>{btnLabel}</button>
	</div>
</form>

<!-- JSON-LD structured data — free version (includes publisher links) -->
<script type="application/ld+json" set:html={JSON.stringify(schemaLd)} />

<style>
	.emdash-form-embed {
		max-width: 40rem;
		font-family: inherit;
	}
	.emdash-form-embed__fields {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}
	.emdash-form-embed__group {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		min-width: 0;
		width: 100%;
	}
	.emdash-form-embed__group--half {
		width: calc(50% - 0.5rem);
	}
	.emdash-form-embed__group--third {
		width: calc(33.333% - 0.667rem);
	}
	.emdash-form-embed__label {
		font-size: 0.875rem;
		font-weight: 500;
	}
	.emdash-form-embed__required {
		color: #dc2626;
		margin-left: 0.125rem;
	}
	.emdash-form-embed__input {
		padding: 0.5rem 0.75rem;
		border: 1px solid #d1d5db;
		border-radius: 0.5rem;
		font-size: 0.875rem;
		font-family: inherit;
		outline: none;
		transition: border-color 0.15s;
	}
	.emdash-form-embed__input:focus {
		border-color: #3b82f6;
		box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.15);
	}
	.emdash-form-embed__textarea {
		resize: vertical;
	}
	.emdash-form-embed__radio-group,
	.emdash-form-embed__checkbox-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.emdash-form-embed__radio-label,
	.emdash-form-embed__checkbox-label {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.875rem;
		cursor: pointer;
	}
	.emdash-form-embed__help {
		font-size: 0.75rem;
		color: #6b7280;
		margin: 0;
	}
	.emdash-form-embed__submit {
		padding: 0.625rem 1.5rem;
		background-color: #2563eb;
		color: #fff;
		border: none;
		border-radius: 0.5rem;
		font-size: 0.875rem;
		font-weight: 600;
		cursor: pointer;
		transition: background-color 0.15s;
	}
	.emdash-form-embed__submit:hover {
		background-color: #1d4ed8;
	}
	.emdash-form-embed__actions {
		display: flex;
		gap: 0.75rem;
		margin-top: 1.25rem;
		padding-top: 1rem;
	}
	.emdash-form-embed__reset {
		padding: 0.625rem 1.5rem;
		background-color: transparent;
		color: #374151;
		border: 1px solid #d1d5db;
		border-radius: 0.5rem;
		font-size: 0.875rem;
		font-weight: 500;
		cursor: pointer;
		transition: background-color 0.15s;
	}
	.emdash-form-embed__reset:hover {
		background-color: #f3f4f6;
	}
	/* Divider */
	.emdash-form-embed__divider {
		width: 100%;
		border: none;
		border-top: 1px solid #d1d5db;
		margin: 0.5rem 0;
	}
	/* Toggle (switch) */
	.emdash-form-embed__toggle-label {
		display: inline-flex;
		align-items: center;
		cursor: pointer;
	}
	.emdash-form-embed__toggle-input {
		display: none;
	}
	.emdash-form-embed__toggle-switch {
		width: 2.5rem;
		height: 1.375rem;
		background-color: #d1d5db;
		border-radius: 9999px;
		position: relative;
		transition: background-color 0.2s;
	}
	.emdash-form-embed__toggle-switch::after {
		content: "";
		position: absolute;
		top: 0.125rem;
		left: 0.125rem;
		width: 1.125rem;
		height: 1.125rem;
		background-color: #fff;
		border-radius: 9999px;
		transition: transform 0.2s;
	}
	.emdash-form-embed__toggle-input:checked + .emdash-form-embed__toggle-switch {
		background-color: #3b82f6;
	}
	.emdash-form-embed__toggle-input:checked + .emdash-form-embed__toggle-switch::after {
		transform: translateX(1.125rem);
	}
	/* Rating (stars) */
	.emdash-form-embed__rating-group {
		display: flex;
		gap: 0.25rem;
	}
	.emdash-form-embed__rating-star {
		cursor: pointer;
		position: relative;
	}
	.emdash-form-embed__rating-star input {
		display: none;
	}
	.emdash-form-embed__star {
		font-size: 1.5rem;
		color: #d1d5db;
		transition: color 0.2s, transform 0.2s;
		display: inline-block;
	}
	.emdash-form-embed__star.efb-star-active {
		color: #f59e0b;
	}
	.emdash-form-embed__star.efb-star-animate {
		animation: efb-star-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
	}
	.emdash-form-embed__rating-star:hover .emdash-form-embed__star {
		transform: scale(1.2);
	}
	@keyframes efb-star-pop {
		0% { transform: scale(1); }
		50% { transform: scale(1.35); }
		100% { transform: scale(1); }
	}
	/* Five-point scale */
	.emdash-form-embed__scale-group {
		display: flex;
		gap: 0.5rem;
	}
	.emdash-form-embed__scale-option {
		display: flex;
		flex-direction: column;
		align-items: center;
		cursor: pointer;
		padding: 0.375rem 0.75rem;
		border: 1px solid #d1d5db;
		border-radius: 0.375rem;
		font-size: 0.875rem;
		transition: background-color 0.15s, border-color 0.15s;
	}
	.emdash-form-embed__scale-option input {
		display: none;
	}
	.emdash-form-embed__scale-option:has(input:checked) {
		background-color: #3b82f6;
		color: #fff;
		border-color: #3b82f6;
	}
	/* Signature */
	.emdash-form-embed__signature-pad {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.emdash-form-embed__signature-canvas {
		border: 1px solid #d1d5db;
